{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es2015", "dom"],
    "types": ["node"],
    "rootDir": "..",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    // We don't actually need to output anything
    "noEmit": true
  },
  "include": [
    "./*"
  ]
}
